<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Goodnight Check Engine Light | Booking</title>
    <style>
        :root { --primary: #007bff; --secondary: #28a745; --dark: #1a1a1a; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; padding: 20px; }
        <div style="text-align: center; padding: 20px; background-color: #1a1a1a; color: white; border-bottom: 3px solid #d4af37;">
    <img src="logo.png" alt="Goodnight Check Engine Light" style="width: 180px; border-radius: 10px; margin-bottom: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.5);">
    <h1 style="margin: 0; font-size: 26px; letter-spacing: 1px;">Goodnight Check Engine Light</h1>
    <p style="margin: 5px 0; font-style: italic; color: #d4af37;">Mobile Diagnostics & Repair</p>
    
    <a href="tel:YOUR-PHONE-NUMBER" style="display: inline-block; background-color: #28a745; color: white; padding: 15px 30px; border-radius: 50px; text-decoration: none; font-weight: bold; margin-top: 15px; font-size: 18px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);">
        📞 CALL NOW
    </a>
</div>
.container { max-width: 600px; margin: auto; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        h1 { color: var(--dark); text-align: center; }
        .form-group { margin-bottom: 15px; }
        input, select { width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 8px; box-sizing: border-box; }
        .time-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 15px; }
        .slot-btn { padding: 10px; border: 2px solid var(--primary); background: none; cursor: pointer; border-radius: 6px; color: var(--primary); font-weight: bold; }
        .slot-btn.selected { background: var(--primary); color: white; }
        #confirmBtn { width: 100%; padding: 15px; background: var(--secondary); color: white; border: none; border-radius: 8px; margin-top: 20px; cursor: pointer; font-size: 1.1em; display: none; }
        .camera-section { margin-top: 30px; border-top: 2px solid #eee; pt: 20px; }
        .cam-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 10px; }
        .cam-box { background: #000; height: 100px; border-radius: 5px; color: white; display: flex; align-items: center; justify-content: center; font-size: 12px; }
    </style>
</head>
<body>

<div class="container">
    <h1>Goodnight Check Engine Light</h1>
    <p style="text-align: center;">Schedule your service below</p>
    
    <div class="form-group">
        <label>Name</label>
        <input type="text" id="custName" placeholder="Your Name">
    </div>

    <div class="form-group">
        <label>Service Type (Labor Time)</label>
        <select id="laborTime" onchange="generateSlots()">
            <option value="1">Diagnostics (1.0 hr)</option>
            <option value="2">Brakes/Suspension (2.0 hrs)</option>
            <option value="4">Major Repair (4.0 hrs)</option>
        </select>
    </div>

    <div class="form-group">
        <label>Date</label>
        <input type="date" id="appDate" onchange="generateSlots()">
    </div>

    <div id="slotsContainer" class="time-grid"></div>
    <button id="confirmBtn">Confirm Appointment</button>

    <div class="camera-section">
        <h3>Shop Live Feed (Monitoring)</h3>
        <div class="cam-grid">
            <div class="cam-box">Cam 1: Bay</div>
            <div class="cam-box">Cam 2: Entry</div>
        </div>
    </div>
</div>

<script>
    const container = document.getElementById('slotsContainer');
    const confirmBtn = document.getElementById('confirmBtn');
    let selectedInfo = {};

    function generateSlots() {
        container.innerHTML = '';
        const labor = parseFloat(document.getElementById('laborTime').value);
        const maxFinish = 19.5; // 7:30 PM (50% rule)

        for (let h = 9; h < 18; h++) {
            if (h + labor <= maxFinish) {
                const timeStr = `${h > 12 ? h - 12 : h}:00 ${h >= 12 ? 'PM' : 'AM'}`;
                const btn = document.createElement('button');
                btn.className = 'slot-btn';
                btn.textContent = timeStr;
                btn.onclick = () => {
                    document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
                    btn.classList.add('selected');
                    selectedInfo = { time: timeStr, date: document.getElementById('appDate').value };
                    confirmBtn.style.display = 'block';
                };
                container.appendChild(btn);
            }
        }
    }

    confirmBtn.onclick = () => {
        alert(`Booking requested for ${selectedInfo.date} at ${selectedInfo.time}. We will contact you shortly!`);
    };
</script>

</body>
</html>
